<style>
*{margin:0;padding:0;box-sizing:border-box;}
:root{
  --ink:#111;
  --cream:#F7F3ED;
  --red:#C41E3A;
  --gold:#B8860B;
  --muted:#6B6560;
  --border:rgba(0,0,0,0.1);
  --dark:#0F0F0F;
}
html{scroll-behavior:smooth;}
body{background:var(--cream);color:var(--ink);font-family:'Inter',sans-serif;font-weight:300;overflow-x:hidden;}

/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:100;display:flex;justify-content:space-between;align-items:center;padding:18px 48px;background:rgba(247,243,237,0.95);backdrop-filter:blur(16px);border-bottom:1px solid var(--border);}
.nav-logo{font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:13px;letter-spacing:2px;text-transform:uppercase;color:var(--ink);text-decoration:none;}
.nav-links{display:flex;gap:32px;list-style:none;}
.nav-links a{font-family:'Space Grotesk',sans-serif;font-size:11px;font-weight:500;letter-spacing:2px;text-transform:uppercase;color:var(--muted);text-decoration:none;transition:color 0.2s;}
.nav-links a:hover{color:var(--ink);}

/* HERO */
.hero{min-height:100vh;display:grid;grid-template-columns:1fr 1fr;padding-top:80px;overflow:hidden;}
.hero-left{display:flex;flex-direction:column;justify-content:center;padding:80px 56px 80px 80px;}
.hero-kicker{font-family:'Space Grotesk',sans-serif;font-size:10px;font-weight:600;letter-spacing:4px;text-transform:uppercase;color:var(--red);margin-bottom:24px;display:flex;align-items:center;gap:14px;}
.hero-kicker::before{content:'';display:block;width:28px;height:1px;background:var(--red);}
h1{font-family:'Playfair Display',serif;font-size:clamp(52px,6vw,88px);line-height:0.88;font-weight:900;letter-spacing:-3px;margin-bottom:10px;}
.hero-tagline{font-family:'Playfair Display',serif;font-style:italic;font-size:clamp(16px,2vw,22px);color:var(--muted);margin-bottom:36px;}
.hero-desc{font-size:15px;line-height:1.8;color:rgba(17,17,17,0.7);max-width:420px;margin-bottom:40px;}
.hero-meta{border-top:1px solid var(--border);border-bottom:1px solid var(--border);padding:20px 0;margin-bottom:28px;display:flex;flex-direction:column;gap:10px;}
.meta-row{display:flex;gap:12px;align-items:baseline;}
.meta-label{font-family:'Space Grotesk',sans-serif;font-size:9px;font-weight:600;letter-spacing:3px;text-transform:uppercase;color:var(--muted);min-width:68px;}
.meta-val{font-family:'Space Grotesk',sans-serif;font-size:13px;font-weight:500;color:var(--ink);}
.sponsor-fine{font-family:'Space Grotesk',sans-serif;font-size:8px;letter-spacing:0.5px;color:var(--muted);opacity:0.55;line-height:1.6;}

/* HERO RIGHT */
.hero-right{position:relative;background:linear-gradient(145deg,#1a2a5e 0%,#0d1530 45%,#8b0000 100%);overflow:hidden;}
.passport-stack{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;}
.passport-img-back{position:absolute;width:50%;top:70px;left:28px;box-shadow:0 24px 60px rgba(0,0,0,0.55);border-radius:3px;overflow:hidden;transform:rotate(-3.5deg);z-index:1;transition:transform 0.4s;}
.passport-img-back:hover{transform:rotate(-1deg) scale(1.03);z-index:3;}
.passport-img-front{position:absolute;width:54%;bottom:44px;right:24px;box-shadow:0 24px 60px rgba(0,0,0,0.65);border-radius:3px;overflow:hidden;transform:rotate(2.5deg);z-index:2;transition:transform 0.4s;}
.passport-img-front:hover{transform:rotate(0.5deg) scale(1.03);z-index:3;}
.passport-img-back img,.passport-img-front img{width:100%;display:block;}
.passport-caption{position:absolute;bottom:0;left:0;right:0;padding:20px 12px 10px;background:linear-gradient(to top,rgba(0,0,0,0.75),transparent);font-family:'Space Grotesk',sans-serif;font-size:8px;font-weight:600;letter-spacing:2px;text-transform:uppercase;color:rgba(255,255,255,0.5);}

/* SECTION BASE */
.section{padding:96px 80px;}
.section-dark{background:var(--dark);color:#F7F3ED;}
.section-tinted{background:#EDE8E0;}
.section-header{margin-bottom:56px;}
.section-header .kicker{font-family:'Space Grotesk',sans-serif;font-size:10px;font-weight:600;letter-spacing:4px;text-transform:uppercase;color:var(--red);margin-bottom:14px;display:block;}
.section-header h2{font-family:'Playfair Display',serif;font-size:clamp(32px,4.5vw,56px);line-height:1;font-weight:900;letter-spacing:-1.5px;}
.section-dark .section-header .kicker{color:rgba(247,243,237,0.4);}
.section-dark .section-header h2{color:#F7F3ED;}
.section-header p{font-size:15px;line-height:1.75;color:rgba(17,17,17,0.6);max-width:540px;margin-top:16px;}
.section-dark .section-header p{color:rgba(247,243,237,0.5);}

/* CONCEPT + POLITICS */
.two-col{display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:start;}
.copy-block h3{font-family:'Playfair Display',serif;font-size:clamp(22px,3vw,34px);font-weight:700;line-height:1.1;letter-spacing:-0.5px;margin-bottom:20px;}
.copy-block p{font-size:15px;line-height:1.85;color:rgba(17,17,17,0.68);margin-bottom:16px;}
.pull-quote{font-family:'Playfair Display',serif;font-style:italic;font-size:clamp(17px,2.2vw,22px);line-height:1.5;border-left:3px solid var(--red);padding-left:24px;color:var(--ink);margin:28px 0;}

/* PASSPORT GALLERY */
.passport-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;}
.passport-cell{border-radius:3px;overflow:hidden;position:relative;box-shadow:0 12px 40px rgba(0,0,0,0.4);transition:transform 0.4s;}
.passport-cell:hover{transform:translateY(-6px) scale(1.02);}
.passport-cell img{width:100%;display:block;}
.passport-cell-label{position:absolute;bottom:0;left:0;right:0;padding:24px 12px 10px;background:linear-gradient(to top,rgba(0,0,0,0.75),transparent);font-family:'Space Grotesk',sans-serif;font-size:8px;font-weight:600;letter-spacing:2px;text-transform:uppercase;color:rgba(255,255,255,0.55);}

/* STATION CARDS — LOGO FORMAT */
.stations-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;}

.station-card{aspect-ratio:4/3;border-radius:4px;overflow:hidden;position:relative;box-shadow:0 4px 16px rgba(0,0,0,0.2);transition:transform 0.3s;}
.station-card:hover{transform:translateY(-4px);}

.station-card-inner{
  width:100%;height:100%;
  display:flex;flex-direction:column;
  align-items:center;justify-content:space-between;
  padding:14px 14px 12px;
  position:relative;
}

.station-num{
  font-family:'Space Grotesk',sans-serif;
  font-size:8px;font-weight:700;
  letter-spacing:3px;
  color:rgba(255,255,255,0.3);
  align-self:flex-start;
}

.station-logo-wrap{
  flex:1;
  display:flex;align-items:center;justify-content:center;
  width:100%;
  margin:10px 0;
  padding:10px 14px;
  border-radius:3px;
}

.station-logo{
  max-width:100%;
  max-height:52px;
  object-fit:contain;
  display:block;
}

.station-bottom{
  width:100%;
  border-top:1px solid rgba(255,255,255,0.15);
  padding-top:8px;
  text-align:center;
}

.station-country{
  font-family:'Playfair Display',serif;
  font-size:16px;font-weight:900;
  color:white;
  line-height:1;
  margin-bottom:3px;
}

.station-pac{
  font-family:'Space Grotesk',sans-serif;
  font-size:6px;font-weight:600;
  letter-spacing:1.5px;text-transform:uppercase;
  color:rgba(255,255,255,0.45);
  line-height:1.4;
}

/* JOURNEY STEPS */
.journey-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:rgba(247,243,237,0.07);}
.journey-step{background:var(--dark);padding:36px 30px;border:1px solid rgba(247,243,237,0.07);transition:background 0.25s;}
.journey-step:hover{background:rgba(247,243,237,0.04);}
.step-num{font-family:'Space Grotesk',sans-serif;font-size:9px;font-weight:700;letter-spacing:3px;color:rgba(247,243,237,0.2);margin-bottom:20px;display:block;}
.step-icon{font-size:26px;margin-bottom:14px;display:block;}
.journey-step h3{font-family:'Space Grotesk',sans-serif;font-size:14px;font-weight:700;letter-spacing:0.5px;text-transform:uppercase;color:#F7F3ED;margin-bottom:10px;}
.journey-step p{font-size:13px;line-height:1.7;color:rgba(247,243,237,0.48);margin-bottom:10px;}
.step-note{font-family:'Space Grotesk',sans-serif;font-size:9px;font-weight:600;letter-spacing:1.5px;text-transform:uppercase;color:rgba(247,243,237,0.22);line-height:1.5;}
.sponsored-tag{display:inline-block;margin-top:12px;font-family:'Space Grotesk',sans-serif;font-size:8px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--gold);border:1px solid rgba(184,134,11,0.35);padding:3px 10px;border-radius:2px;}

/* ABOUT + CONTACT */
.about-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:48px;}
.about-col-label{font-family:'Space Grotesk',sans-serif;font-size:9px;font-weight:700;letter-spacing:4px;text-transform:uppercase;color:rgba(247,243,237,0.3);margin-bottom:20px;display:block;}
.person-role{font-family:'Space Grotesk',sans-serif;font-size:8px;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:var(--gold);margin-bottom:8px;display:block;margin-top:24px;}
.person-name{font-family:'Playfair Display',serif;font-size:22px;font-weight:700;color:#F7F3ED;margin-bottom:8px;}
.person-bio{font-size:13px;line-height:1.75;color:rgba(247,243,237,0.42);margin-bottom:20px;}
.contact-item{padding:14px 0;border-top:1px solid rgba(247,243,237,0.07);}
.contact-item:first-child{border-top:none;padding-top:0;}
.ci-label{font-family:'Space Grotesk',sans-serif;font-size:8px;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:rgba(247,243,237,0.25);margin-bottom:4px;display:block;}
.ci-val{font-family:'Space Grotesk',sans-serif;font-size:15px;font-weight:500;color:#F7F3ED;text-decoration:none;transition:color 0.2s;display:block;}
.ci-val:hover{color:var(--gold);}
.event-item{padding:14px 0;border-top:1px solid rgba(247,243,237,0.07);}
.event-item:first-child{border-top:none;padding-top:0;}
.ei-label{font-family:'Space Grotesk',sans-serif;font-size:8px;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:rgba(247,243,237,0.25);margin-bottom:4px;display:block;}
.ei-val{font-family:'Space Grotesk',sans-serif;font-size:14px;font-weight:500;color:rgba(247,243,237,0.65);line-height:1.4;}

/* FOOTER */
footer{background:#080808;padding:28px 80px;display:flex;justify-content:space-between;align-items:center;border-top:1px solid rgba(255,255,255,0.04);}
.footer-text{font-family:'Space Grotesk',sans-serif;font-size:10px;font-weight:500;letter-spacing:2px;text-transform:uppercase;color:rgba(255,255,255,0.18);}

/* RESPONSIVE */
@media(max-width:960px){
  nav{padding:16px 20px;}
  .nav-links{display:none;}
  .hero{grid-template-columns:1fr;}
  .hero-left{padding:48px 24px;}
  .hero-right{min-height:300px;}
  .section{padding:72px 24px;}
  .two-col,.journey-grid,.about-grid,.passport-grid{grid-template-columns:1fr;}
  .stations-grid{grid-template-columns:repeat(2,1fr);}
  .passport-grid{grid-template-columns:repeat(2,1fr);}
  footer{padding:24px;flex-direction:column;gap:8px;text-align:center;}
}
</style>
