  pickwick:  {e:'🍻',bg:'linear-gradient(135deg,#3D3000,#261E00)',title:'Pickwick Tavern Visa',sub:'Pickwick Tavern',earned:false,hood:'East Hills · Cherry St SE',hint:'Visit Pickwick Tavern'},
  mangiamo:  {e:'🍝',bg:'linear-gradient(135deg,#6B2A00,#3D1800)',title:'Mangiamo Visa',sub:'Mangiamo',earned:false,hood:'East Hills · Lake Dr SE',hint:'Visit Mangiamo'},
  books:     {e:'📚',bg:'linear-gradient(135deg,#1A2D5C,#0F1A38)',title:'Books & Mortar Visa',sub:'Books & Mortar',earned:false,hood:'East Hills · Cherry St SE',hint:'Visit Books & Mortar'},
  hopscotch: {e:'🧸',bg:'linear-gradient(135deg,#4A8B3A,#2D5C22)',title:'Hopscotch Visa',sub:"Hopscotch Children's Store",earned:false,hood:'East Hills · Cherry St SE',hint:"Visit Hopscotch Children's Store"},
  rps:       {e:'👗',bg:'linear-gradient(135deg,#4A2C1A,#2E1A0F)',title:'Rock Paper Scissors Visa',sub:'Rock Paper Scissors Consignment',earned:false,hood:'East Hills · Diamond Ave SE',hint:'Visit Rock Paper Scissors Consignment'},
  counting:  {e:'🛍️',bg:'linear-gradient(135deg,#1A1A4A,#0F0F2E)',title:'Counting House Visa',sub:'The Counting House',earned:false,hood:'Wealthy St SE',hint:'Visit The Counting House'},
  floral:    {e:'💐',bg:'linear-gradient(135deg,#4A1A3D,#2E0F26)',title:'New Design Floral Visa',sub:'New Design Floral',earned:false,hood:'East Hills · Cherry St SE',hint:'Visit New Design Floral'},
  kula:      {e:'🧘',bg:'linear-gradient(135deg,#1A4A3D,#0F2E26)',title:'Kula Yoga Visa',sub:'Kula Yoga',earned:false,hood:'Wealthy St SE',hint:'Visit Kula Yoga'},
  jude:      {e:'✂️',bg:'linear-gradient(135deg,#2A2A2A,#141414)',title:"Jude's Barbershop Visa",sub:"Jude's Barbershop",earned:false,hood:'Eastown · Wealthy St SE',hint:"Visit Jude's Barbershop"},
  lorde:     {e:'💄',bg:'linear-gradient(135deg,#6B1A5C,#3D0F36)',title:'Lorde Beauty Visa',sub:'Lorde Beauty and Cosmetics',earned:false,hood:'Eastown · Wealthy St SE',hint:'Visit Lorde Beauty and Cosmetics'},
  cocoon:    {e:'🎨',bg:'linear-gradient(135deg,#3D1A5C,#261040)',title:'Cocoon Art Visa',sub:'Cocoon Art Space',earned:false,hood:'Eastown · Lake Dr SE',hint:'Visit Cocoon Art Space'},
  joyful:    {e:'🎵',bg:'linear-gradient(135deg,#1A3D5C,#0F2638)',title:'Joyful Sounds Visa',sub:'Joyful Sounds Music Studio',earned:false,hood:'East Hills · Lake Dr SE',hint:'Visit Joyful Sounds Music Studio'},
  streetfair:{e:'🎪',bg:'linear-gradient(135deg,#1A1A18,#4A3A08,#1A1A18)',title:'Eastown Street Fair 2026',sub:'Eastown Community Association',earned:false,hood:'Eastown',hint:'Attend the Street Fair · September 19, 2026 only'},
};

const ratings = {
  '👍': {e:'☕', name:'Tuesday Morning', detail:'Eastown · May 20, 2026', bg:'linear-gradient(135deg,#2C5F4A,#1A3D30)', label:'👍 Loved it'},
  '❤️': {e:'✨', name:'Golden Hour',     detail:'Eastown · May 20, 2026', bg:'linear-gradient(135deg,#B8860B,#7A5A08)', label:'❤️ Amazing'},
  '👎': {e:'🌧️', name:'Rainy Tuesday',  detail:'Eastown · May 20, 2026', bg:'linear-gradient(135deg,#3A4A6B,#1A2540)', label:'👎 Not great'},
};

let selectedRating = '👍';

function selectRating(el, emoji, label) {
  document.querySelectorAll('.rb-btn').forEach(b => b.classList.remove('selected'));
  el.classList.add('selected');
  selectedRating = emoji;
  document.getElementById('rb-continue').classList.add('ready');
}

function go(screen) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.querySelectorAll('.demo-nav button').forEach(b => b.classList.remove('active'));
  document.getElementById('screen-'+screen).classList.add('active');
  document.getElementById('nav-'+screen).classList.add('active');

  if(screen === 'gen') {
    const r = ratings[selectedRating] || ratings['👍'];
    document.getElementById('gen-icon').textContent = r.e;
    setTimeout(() => go('visa'), 2200);
  }
  if(screen === 'visa') {
    const r = ratings[selectedRating] || ratings['👍'];
    document.getElementById('visa-emoji').textContent = r.e;
    document.getElementById('visa-name').textContent = r.name;
    document.getElementById('visa-detail').textContent = r.detail;
    document.getElementById('visa-bg').style.background = r.bg;
    document.getElementById('visa-rating-val').textContent = r.label;
  }
  if(screen === 'collection') {
    setTimeout(() => {
      document.getElementById('col-prog').style.width = '6%';
    }, 400);
  }
}

function openM(key) {
  const d = visaData[key];
  const icon = document.getElementById('m-icon');
  icon.textContent = d.e;
  icon.style.background = d.bg;
  document.getElementById('m-title').textContent = d.title;
  document.getElementById('m-sub').textContent = d.sub;
  document.getElementById('m-hood').textContent = d.hood;
  const st = document.getElementById('m-status');
  st.textContent = d.earned ? '✓ Visa earned' : '🔒 Not yet earned';
  st.className = 'modal-val ' + (d.earned ? 'good' : 'muted');
  document.getElementById('m-earned-r').style.display = d.earned ? 'flex' : 'none';
  document.getElementById('m-rating-r').style.display = d.earned ? 'flex' : 'none';
  document.getElementById('m-proof-r').style.display = d.earned ? 'flex' : 'none';
  document.getElementById('m-hint-r').style.display = d.earned ? 'none' : 'flex';
  if(d.earned) {
    document.getElementById('m-earned').textContent = d.issuedAt;
    document.getElementById('m-rating').textContent = d.rating;
  }
  document.getElementById('m-hint').textContent = d.hint;
  document.getElementById('modal').classList.add('open');
}

function closeM(e) {
  if(!e || e.target === document.getElementById('modal'))
    document.getElementById('modal').classList.remove('open');
}

function colFilter(cat, btn) {
  document.querySelectorAll('.col-filter').forEach(t => t.classList.remove('active'));
  btn.classList.add('active');
  const cats = ['food','shop','wellness','arts'];
  if(cat === 'all') {
    document.querySelectorAll('.col-badge,.sf-card').forEach(c => c.style.display='');
    cats.forEach(c => {
      document.getElementById('sl-'+c).style.display='';
      document.getElementById('cg-'+c).style.display='grid';
    });
  } else if(cat === 'earned') {
    document.querySelectorAll('.col-badge,.sf-card').forEach(c => {
      c.style.display = c.classList.contains('earned') ? '' : 'none';
    });
    cats.forEach(c => {
      document.getElementById('sl-'+c).style.display='';
      document.getElementById('cg-'+c).style.display='grid';
    });
  } else {
    document.querySelectorAll('.col-badge,.sf-card').forEach(c => {
      c.style.display = c.dataset.cat === cat ? '' : 'none';
    });
    cats.forEach(c => {
      const show = c === cat;
      document.getElementById('sl-'+c).style.display = show ? '' : 'none';
      document.getElementById('cg-'+c).style.display = show ? 'grid' : 'none';
    });
  }
}
</script>
